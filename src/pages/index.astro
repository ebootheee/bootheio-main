---
import { getEmDashCollection, getEntryTerms } from "emdash";
import { Image } from "emdash/ui";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import { getReadingTime } from "../utils/reading-time";

const { entries: posts, cacheHint } = await getEmDashCollection("posts");

Astro.cache.set(cacheHint);

const sortedPosts = posts.toSorted((a, b) => {
	const dateA = a.data.publishedAt?.getTime() ?? 0;
	const dateB = b.data.publishedAt?.getTime() ?? 0;
	return dateB - dateA;
});

const recentPosts = sortedPosts.slice(0, 6);
const hasMorePosts = sortedPosts.length > 6;

const postsWithTags = await Promise.all(
	recentPosts.map(async (post) => {
		const tags = await getEntryTerms("posts", post.data.id, "tag");
		const bylines = post.data.bylines ?? [];
		return {
			post,
			tags: tags.map((t) => ({ slug: t.slug, label: t.label })),
			bylines,
		};
	})
);

// Guestbook entries (placeholder)
const guestbookEntries = [
	{ name: "xX_c0d3r_Xx", date: "03/15/2026", message: "Cool site! Love the retro vibes." },
	{ name: "anonymous", date: "03/10/2026", message: "nice 3D prints, where do u get ur filament?" },
	{ name: "webmaster_dan", date: "02/28/2026", message: "Added you to my webring! check it out" },
];
---

<Base title="boothe.io" description="Technical writing, engineering projects, and 3D prints.">
	<!-- Hero Section -->
	<section class="hero">
		<div class="hero-inner">
			<p class="hero-status">
				<span class="status-dot"></span>
				online since 2025
			</p>

			<h1 class="hero-title">
				Technical Blog<br/>
				<span class="hero-title-accent">& Projects</span>
			</h1>

			<p class="hero-description">
				Exploring software development, 3D printing, and engineering deep-dives.
				Sometimes I build useful things. Sometimes I just build things.
			</p>

			<!-- Decorative divider -->
			<div class="hero-divider"></div>
		</div>
	</section>

	<!-- Recent Posts -->
	<section class="section">
		<div class="section-inner">
			<div class="section-header">
				<div>
					<span class="section-label">// latest</span>
					<h2 class="section-title">Recent Writing</h2>
				</div>
				{hasMorePosts && (
					<a href="/posts" class="section-link">
						view all <span class="arrow">&rarr;</span>
					</a>
				)}
			</div>

			{recentPosts.length === 0 ? (
				<div class="empty-state">
					<h3>No posts yet</h3>
					<p>Create your first post in the admin panel.</p>
					<a href="/_emdash/admin/content/posts/new" class="btn">Create a post</a>
				</div>
			) : (
				<div class="posts-grid">
					{postsWithTags.map(({ post, tags, bylines }) => (
						<PostCard
							title={post.data.title ?? "Untitled"}
							excerpt={post.data.excerpt}
							featuredImage={post.data.featured_image}
							href={`/posts/${post.id}`}
							date={post.data.publishedAt ?? undefined}
							readingTime={getReadingTime(post.data.content)}
							tags={tags}
							bylines={bylines}
						/>
					))}
				</div>
			)}
		</div>
	</section>

	<!-- Guestbook Section -->
	<section class="section">
		<div class="section-inner">
			<div class="guestbook">
				<div class="guestbook-corner-tl">*~</div>
				<div class="guestbook-corner-tr">~*</div>

				<h3 class="guestbook-title">
					<span class="blink">&gt;</span> Guestbook
				</h3>

				<div class="guestbook-entries">
					{guestbookEntries.map((entry) => (
						<div class="guestbook-entry">
							<div class="guestbook-meta">
								<span class="guestbook-name">{entry.name}</span>
								<span class="guestbook-date">{entry.date}</span>
							</div>
							<p class="guestbook-message">{entry.message}</p>
						</div>
					))}
				</div>

				<button
					class="guestbook-btn"
					onclick="alert('Guestbook coming soon! (When I figure out how to set up a CGI-BIN script...)')"
				>
					Sign the Guestbook
				</button>
			</div>
		</div>
	</section>
</Base>

<style>
	/* Hero */
	.hero {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 5rem var(--spacing-6) 4rem;
		position: relative;
	}

	.hero-inner {
		max-width: 800px;
	}

	.hero-status {
		font-family: var(--font-pixel);
		font-size: 0.875rem;
		color: rgba(245, 158, 11, 0.6);
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 1rem;
	}

	.status-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--color-retro-green);
		animation: glow-pulse 3s ease-in-out infinite;
	}

	.hero-title {
		font-family: var(--font-serif) !important;
		font-size: clamp(3rem, 8vw, 4.5rem);
		font-weight: 400 !important;
		line-height: 1.1;
		color: var(--color-text);
		margin-bottom: 1.5rem;
	}

	.hero-title-accent {
		font-style: italic;
		color: rgba(34, 211, 238, 0.8);
	}

	.hero-description {
		font-size: 0.875rem;
		line-height: 1.7;
		color: var(--color-muted);
		max-width: 540px;
	}

	.hero-divider {
		margin-top: 4rem;
		height: 1px;
		background: linear-gradient(to right, rgba(34, 211, 238, 0.2), var(--color-border), transparent);
	}

	/* Sections */
	.section {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 0 var(--spacing-6) 4rem;
	}

	.section-inner {
		max-width: var(--wide-width);
	}

	.section-header {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		margin-bottom: 2rem;
	}

	.section-label {
		font-family: var(--font-pixel);
		font-size: 0.625rem;
		color: rgba(245, 158, 11, 0.4);
		text-transform: uppercase;
		letter-spacing: 0.15em;
	}

	.section-title {
		font-family: var(--font-serif) !important;
		font-size: var(--font-size-3xl);
		font-weight: 400 !important;
		color: var(--color-text);
		margin-top: 0.25rem;
	}

	.section-link {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.section-link:hover {
		color: var(--color-accent);
	}

	.section-link .arrow {
		display: inline-block;
		transition: transform 0.2s ease;
	}

	.section-link:hover .arrow {
		transform: translateX(2px);
	}

	/* Posts Grid */
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
	}

	/* Guestbook */
	.guestbook {
		max-width: 420px;
		border: 1px dashed rgba(245, 158, 11, 0.3);
		border-radius: var(--radius-lg);
		background: rgba(245, 158, 11, 0.02);
		padding: 1.5rem;
		position: relative;
		overflow: hidden;
	}

	.guestbook-corner-tl,
	.guestbook-corner-tr {
		position: absolute;
		top: 0.5rem;
		font-family: var(--font-pixel);
		font-size: 0.75rem;
		color: rgba(245, 158, 11, 0.2);
	}
	.guestbook-corner-tl { left: 0.5rem; }
	.guestbook-corner-tr { right: 0.5rem; }

	.guestbook-title {
		font-family: var(--font-pixel) !important;
		font-size: 1.125rem;
		color: var(--color-retro);
		margin-bottom: 1rem;
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.guestbook-entries {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin-bottom: 1rem;
	}

	.guestbook-entry {
		border-bottom: 1px solid rgba(245, 158, 11, 0.1);
		padding-bottom: 0.75rem;
	}

	.guestbook-entry:last-child {
		border-bottom: none;
	}

	.guestbook-meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.75rem;
		margin-bottom: 0.25rem;
	}

	.guestbook-name {
		font-family: var(--font-pixel);
		color: var(--color-retro-green);
	}

	.guestbook-date {
		font-family: var(--font-pixel);
		color: var(--color-muted);
	}

	.guestbook-message {
		font-size: 0.875rem;
		color: var(--color-text-secondary);
	}

	.guestbook-btn {
		font-family: var(--font-pixel);
		font-size: 0.875rem;
		color: var(--color-bg);
		background: var(--color-retro);
		border: none;
		padding: 0.375rem 1rem;
		border-radius: var(--radius);
		cursor: pointer;
		transition: opacity 0.2s ease;
	}

	.guestbook-btn:hover {
		opacity: 0.8;
	}

	/* Empty State */
	.empty-state {
		text-align: center;
		padding: 4rem 1.5rem;
		border: 1px dashed var(--color-border);
		border-radius: var(--radius-lg);
	}

	.empty-state h3 {
		font-family: var(--font-serif) !important;
		font-size: var(--font-size-2xl);
		margin-bottom: 0.5rem;
	}

	.empty-state p {
		color: var(--color-muted);
		margin-bottom: 1rem;
	}

	.btn {
		display: inline-block;
		padding: 0.75rem 1.5rem;
		background: var(--color-accent);
		color: var(--color-on-accent);
		text-decoration: none;
		border-radius: var(--radius);
		font-size: var(--font-size-sm);
		font-weight: 500;
	}

	/* Animations */
	.blink { animation: blink 1s step-end infinite; }

	/* Responsive */
	@media (max-width: 900px) {
		.posts-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 600px) {
		.hero {
			padding: 3rem var(--spacing-4) 2.5rem;
		}
		.section {
			padding: 0 var(--spacing-4) 3rem;
		}
		.posts-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
