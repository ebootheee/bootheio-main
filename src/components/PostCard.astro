---
import type { MediaValue, ContentBylineCredit } from "emdash";
import { Image } from "emdash/ui";

interface Props {
	title: string;
	excerpt?: string;
	featuredImage?: MediaValue | string;
	href: string;
	date?: Date;
	readingTime?: number;
	tags?: Array<{ slug: string; label: string }>;
	bylines?: ContentBylineCredit[];
}

const {
	title,
	excerpt,
	featuredImage,
	href,
	date,
	readingTime,
	tags,
	bylines,
} = Astro.props;

const formattedDate = date
	? date.toLocaleDateString("en-US", {
			year: "numeric",
			month: "short",
			day: "numeric",
		})
	: null;
---

<article class="card">
	<a href={href} class="card-link">
		<!-- Hover glow -->
		<div class="card-glow"></div>

		<div class="card-body">
			<time class="card-date">
				{formattedDate ?? "Draft"}
				{readingTime && <span class="card-reading"> · {readingTime} min</span>}
			</time>

			<h2 class="card-title">{title}</h2>

			{excerpt && <p class="card-excerpt">{excerpt}</p>}
		</div>
	</a>

	{tags && tags.length > 0 && (
		<div class="card-tags">
			{tags.slice(0, 3).map((tag) => (
				<a href={`/tag/${tag.slug}`} class="card-tag">
					{tag.label}
				</a>
			))}
		</div>
	)}
</article>

<style>
	.card {
		position: relative;
	}

	.card-link {
		display: block;
		position: relative;
		padding: 1.25rem;
		border-radius: var(--radius-lg);
		border: 1px solid var(--color-border);
		background: rgba(12, 12, 16, 0.5);
		text-decoration: none;
		color: inherit;
		transition: border-color 0.3s ease, background 0.3s ease;
	}

	.card-link:hover {
		border-color: rgba(34, 211, 238, 0.3);
		background: rgba(20, 20, 24, 0.5);
	}

	.card-glow {
		position: absolute;
		inset: 0;
		border-radius: var(--radius-lg);
		background: rgba(34, 211, 238, 0.02);
		opacity: 0;
		transition: opacity 0.3s ease;
		pointer-events: none;
	}

	.card-link:hover .card-glow {
		opacity: 1;
	}

	.card-body {
		position: relative;
	}

	.card-date {
		display: block;
		font-family: var(--font-mono);
		font-size: 0.6875rem;
		color: var(--color-muted);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: 0.5rem;
	}

	.card-reading {
		color: var(--color-muted);
	}

	.card-title {
		font-family: var(--font-serif) !important;
		font-size: var(--font-size-lg);
		font-weight: 400 !important;
		color: var(--color-text);
		line-height: var(--leading-snug);
		margin-bottom: 0.5rem;
		transition: color 0.2s ease;
	}

	.card-link:hover .card-title {
		color: var(--color-accent);
	}

	.card-excerpt {
		font-size: var(--font-size-sm);
		line-height: var(--leading-relaxed);
		color: var(--color-muted);
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
		margin-top: 0.75rem;
		padding: 0 1.25rem;
	}

	.card-tag {
		display: inline-block;
		padding: 2px 0.5rem;
		font-family: var(--font-mono);
		font-size: 0.625rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-muted);
		border: 1px solid var(--color-border);
		border-radius: 999px;
		text-decoration: none;
		transition: color 0.2s ease, border-color 0.2s ease;
	}

	.card-tag:hover {
		color: var(--color-text);
		border-color: var(--color-text-secondary);
	}
</style>
